# ===================
# DATABASE
# ===================
DATABASE_URL="postgresql://postgres:password@localhost:5432/losev_inci"

# ===================
# JWT AUTHENTICATION
# ===================
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"
JWT_EXPIRATION="7d"
JWT_REFRESH_EXPIRATION="30d"

# ===================
# BACKEND CONFIG
# ===================
BACKEND_PORT=3001
BACKEND_HOST=localhost
NODE_ENV=development
LOG_LEVEL=debug

# ===================
# FRONTEND CONFIG
# ===================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=LÖSEV İncİ
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===================
# CLOUDINARY (File Uploads)
# ===================
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===================
# EMAIL (Optional - SendGrid/Nodemailer)
# ===================
EMAIL_PROVIDER=nodemailer
EMAIL_FROM=noreply@losev-inci.org
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# ===================
# REDIS (Optional - Caching/Sessions)
# ===================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ===================
# ENCRYPTION
# ===================
ENCRYPTION_KEY=your-32-character-encryption-key-here
ENCRYPTION_IV=your-16-character-iv-here

# ===================
# EXTERNAL SERVICES
# ===================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===================
# FEATURE FLAGS
# ===================
ENABLE_DEMO_MODE=true
ENABLE_REALTIME=false
ENABLE_EMAIL_NOTIFICATIONS=false

# ===================
# SECURITY
# ===================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGIN=http://localhost:3000